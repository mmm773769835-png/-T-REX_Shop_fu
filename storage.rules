rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow write access to receipts folder without authentication (for order receipts)
    // This must come before the general rule to take precedence
    match /receipts/{receiptId} {
      allow read: if true;
      allow write: if true;
      allow delete: if false; // Prevent deletion of receipts
    }
    
    // Allow write access to products folder without authentication (for admin panel)
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Allow admin to upload product images
      allow delete: if true; // Allow admin to delete product images
    }
    
    // General rules for all other paths
    match /{allPaths=**} {
      // Allow read access for all users
      allow read: if true;
      
      // Allow write access only for authenticated users
      allow write: if request.auth != null;
      
      // Allow delete access only for admins
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
