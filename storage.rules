rules_version = '2';

// ملاحظة: Firebase Storage غير مستخدم حالياً في هذا المشروع.
// تم قفل جميع الصلاحيات بالكامل لمنع أي وصول غير مصرح به.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
      allow delete: if false;
    }
  }
}
