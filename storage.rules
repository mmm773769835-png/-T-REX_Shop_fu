rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Receipts: read for all, write requires authentication
    match /receipts/{receiptId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false; // Prevent deletion of receipts
    }
    
    // Products: read for all, write/delete requires authentication
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // General rules for all other paths
    match /{allPaths=**} {
      // Allow read access for all users
      allow read: if true;
      
      // Allow write access only for authenticated users
      allow write: if request.auth != null;
      
      // Allow delete access only for admins
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
