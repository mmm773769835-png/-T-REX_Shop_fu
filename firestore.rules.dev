rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development rules - allow read/write for all
    match /{document=**} {
      allow read, write: if true;
    }
    
    // قواعد خاصة للمنتجات
    match /products/{product} {
      allow read, write: if true;
    }
    
    // قواعد خاصة للطلبات
    match /orders/{order} {
      allow read, write: if true;
    }
    
    // قواعد خاصة لبيانات المستخدمين
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}