# ===========================================
# T-REX Shop Server - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Server Configuration
PORT=4001
NODE_ENV=development

# Admin Credentials
ADMIN_USER=owner
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_HASH=  # Generate with: ADMIN_PASSWORD=YourPassword node setup-and-start.js

# JWT Secret - MUST be a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8084

# Twilio Configuration (Optional - OTP codes logged to console without it)
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WHATSAPP_FROM=
