# Copy to .env and fill values

# Admin Authentication
ADMIN_USER=owner
ADMIN_HASH=PUT_BCRYPT_HASH_HERE
ADMIN_EMAIL=admin@t-rex-shop.com

# JWT Secret (use strong random string in production)
JWT_SECRET=put_a_strong_secret_here_min_32_chars

# Twilio Configuration
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=+1234567890

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:19002

# Security
BCRYPT_ROUNDS=10
