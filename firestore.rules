rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // دالة مساعدة للتحقق من أن المستخدم مسجل دخول
    function isLoggedIn() {
      return request.auth != null;
    }
    
    // دالة للتحقق من أن المستخدم هو المدير
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'mmm773769835@gmail.com';
    }
    
    // دالة للتحقق من أن المستخدم يملك البيانات
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // المنتجات - القراءة للجميع، الكتابة للمدير فقط
    match /products/{productId} {
      allow read: if true; // الجميع يقرأ
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // الطلبات - القراءة للمستخدمين المسجلين، الكتابة لمالك الطلب أو المدير
    match /orders/{orderId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && 
                       request.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && 
                       (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // بيانات المستخدمين - كل مستخدم يقرأ ويكتب بياناته فقط
    match /users/{userId} {
      allow read: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow create: if isLoggedIn() && isOwner(userId);
      allow update: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }
    
    // عناوين المستخدمين
    match /addresses/{addressId} {
      allow read: if isLoggedIn() && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && 
                       request.data.userId == request.auth.uid;
      allow update, delete: if isLoggedIn() && 
                               (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}